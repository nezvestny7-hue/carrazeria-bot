# --- BOT BUYRUQLARI ---
@dp.message(CommandStart())
async def start_cmd(message: Message):
    if not await check_subscription(message.from_user.id):
        await message.answer("⚠️ Botdan foydalanish uchun avval kanalimizga obuna bo'ling!", reply_markup=subscription_keyboard())
        return
    await message.answer("Salom! Menga biror `.mp3` musiqa yuboring, uni chinakamiga o'zgartiramiz! 🎧")

@dp.callback_query(F.data == "check_sub")
async def callback_check_sub(call: CallbackQuery):
    if await check_subscription(call.from_user.id):
        await call.message.delete()
        await call.message.answer("🎉 Rahmat! Endi menga bemalol musiqa yuborishingiz mumkin. 🎵")
    else:
        await call.answer("❌ Siz hali kanalga obuna bo'lmadingiz!", show_alert=True)

@dp.message(F.audio)
async def handle_audio(message: Message, state: FSMContext):
    if not await check_subscription(message.from_user.id):
        await message.answer("⚠️ Musiqani qayta ishlash uchun avval kanalimizga a'zo bo'ling!", reply_markup=subscription_keyboard())
        return

    file_id = message.audio.file_id
    file_name = message.audio.file_name or "audio.mp3"
    await state.update_data(file_id=file_id, file_name=file_name)
    
    await message.answer("Ushbu musiqa uchun rejimni tanlang:", reply_markup=effect_keyboard())
    await state.set_state(BotStates.waiting_for_effect_choice)

@dp.callback_query(BotStates.waiting_for_effect_choice, F.data.startswith("eff_"))
async def process_effect_choice(call: CallbackQuery, state: FSMContext):
    await state.update_data(effect=call.data)
    await call.message.delete()
    await call.message.answer("Yaxshi! Endi musiqaning yangi **ijrochisini** (Artist) kiriting:")
    await state.set_state(BotStates.waiting_for_artist)

@dp.message(BotStates.waiting_for_artist)
async def process_artist(message: Message, state: FSMContext):
    await state.update_data(artist=message.text)
    await message.answer("Ajoyib! Endi musiqaning yangi **nomini** (Title) kiriting:")
    await state.set_state(BotStates.waiting_for_title)

@dp.message(BotStates.waiting_for_title)
async def process_title(message: Message, state: FSMContext):
    user_data = await state.get_data()
    title = message.text
    artist = user_data['artist']
    effect = user_data['effect']
    file_id = user_data['file_id']
    file_name = user_data['file_name']
    
    status_msg = await message.answer("⏳ Musiqa serverga yuklanmoqda va qayta ishlanmoqda...")
    custom_path = f"track_{message.from_user.id}_{file_name}"
    
    try:
        file = await bot.get_file(file_id)
        await bot.download_file(file.file_path, custom_path)
        
        if effect == "eff_carrozzeria":
            await status_msg.edit_text("🎛 Carrozzeria 919 SFC: Concert Hall effekti berilmoqda...")
            apply_concert_hall_effect(custom_path)
            caption_text = "🎵 Carrozzeria 919: Concert Hall effekti qo'shildi!"
        else:
            caption_text = "📝 Musiqa teglari muvaffaqiyatli o'zgartirildi!"
            
        try:
            audio = EasyID3(custom_path)
        except Exception:
            from mutagen.mp3 import MP3
            audio = MP3(custom_path, ID3=EasyID3)
            audio.add_tags(ID3=EasyID3)
            audio = EasyID3(custom_path)
            
        audio['artist'] = artist
        audio['title'] = title
        audio.save()
        
        edited_audio = FSInputFile(custom_path, filename=f"{artist} - {title}.mp3")
        await message.reply_audio(audio=edited_audio, caption=caption_text, performer=artist, title=title)
    except Exception as e:
        await message.answer(f"❌ Xatolik yuz berdi: {str(e)}")
    finally:
        if os.path.exists(custom_path):
            os.remove(custom_path)
        await status_msg.delete()
        await state.clear()

