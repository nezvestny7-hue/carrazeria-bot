# --- CARROZZERIA "CONCERT HALL" EFFEKTI FUNKSIYASI ---
def apply_concert_hall_effect(file_path):
    sound = AudioSegment.from_file(file_path, format="mp3")
    
    # 1-aks-sado: 140ms kechikish bilan
    echo_delay1 = 140 
    echo_volume1 = -11
    echo1 = sound - abs(echo_volume1)
    echo1 = AudioSegment.silent(duration=echo_delay1) + echo1
    hall_sound = sound.overlay(echo1)
    
    # 2-aks-sado: 280ms kechikish bilan
    echo_delay2 = 280
    echo_volume2 = -18
    echo2 = sound - abs(echo_volume2)
    echo2 = AudioSegment.silent(duration=echo_delay2) + echo2
    
    final_sound = hall_sound.overlay(echo2)
    final_sound.export(file_path, format="mp3")

